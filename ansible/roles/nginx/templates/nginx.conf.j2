{%- set service_ports = {
    'calibre_web': 8083,
    'kiwix':       8888
} -%}
# nginx.conf.j2 — Hearth nginx configuration template
#
# Rendered by:  ansible roles/nginx via ansible.builtin.template
# Deployed to:  {{ nginx_conf_dest }}
#
# Expected rendered form (with the sample hearth.yaml defaults):
#
#   server {
#       listen 80 default_server;
#       server_name hearth.local;
#       root /var/www/hearth/portal;
#       index index.html;
#
#       # Captive-portal detection — redirect to portal on all OSes
#       location /generate_204        { return 302 http://hearth.local/; }
#       location /hotspot-detect.html { return 302 http://hearth.local/; }
#       location /connecttest.txt     { return 302 http://hearth.local/; }
#       location /ncsi.txt            { return 302 http://hearth.local/; }
#
#       location / { index index.html; try_files $uri $uri/ =404; }
#
#       # Admin API (proxied to the local admin backend)
#       location /api/ { proxy_pass http://127.0.0.1:8000; ... }
#
#       # Service reverse-proxy stubs (uncomment when service is installed)
#       # location /calibre_web/ { proxy_pass http://127.0.0.1:8083/; }
#       # location /kiwix/       { proxy_pass http://127.0.0.1:8888/; }
#       # location /navidrome/   { proxy_pass http://127.0.0.1:4533/; }
#   }

server {
    listen 80 default_server;
    server_name {{ box.domain }};

    root /var/www/hearth/portal;
    index index.html;

    # Captive-portal detection — redirect all OS probes to the portal
    location /generate_204        { return 302 http://{{ box.domain }}/; }
    location /hotspot-detect.html { return 302 http://{{ box.domain }}/; }
    location /connecttest.txt     { return 302 http://{{ box.domain }}/; }
    location /ncsi.txt            { return 302 http://{{ box.domain }}/; }

    location / {
        index index.html;
        try_files $uri $uri/ =404;
    }

    # Admin API (proxied to the local admin backend)
    # Note: no trailing slash on proxy_pass — the full /api/... URI is
    # forwarded to the backend unchanged.
    # client_max_body_size raised to accommodate music/ebook file uploads.
    location /api/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        client_max_body_size 50m;
    }

    # Backend liveness check — also seeds the CSRF cookie for the login page.
    location /healthz {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    # Admin frontend static files — not linked from the portal
    location /admin/ {
        alias /var/www/hearth/admin/;
        index login.html;
        try_files $uri $uri/ /admin/login.html;
    }

{% if services.chat is defined and services.chat.enabled %}
    # -------------------------------------------------------------------------
    # Hearth Chat
    # -------------------------------------------------------------------------

    # No-trailing-slash redirect
    location = /chat { return 301 /chat/; }

    # WebSocket proxy — must come before /chat/ to avoid alias match
    location /chat/ws {
        proxy_pass         http://127.0.0.1:8765;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade    $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_set_header   Host       $host;
        proxy_read_timeout 3600s;
    }

    # Static frontend
    location /chat/ {
        alias /var/www/hearth/chat/;
        index index.html;
        try_files $uri $uri/ /chat/index.html;
    }
{% endif %}

{% if services.kiwix is defined and services.kiwix.enabled %}
    # -------------------------------------------------------------------------
    # Kiwix offline library (Wikipedia, K-12 education, and other ZIM content)
    # -------------------------------------------------------------------------

    # No-trailing-slash redirect
    location = /library { return 301 /library/; }

    # Reverse proxy — kiwix-serve is configured with --urlRootLocation /library
    # so it expects to receive the full /library/... path unchanged.
    location /library/ {
        proxy_pass         http://127.0.0.1:8888;
        proxy_set_header   Host       $host;
        proxy_set_header   X-Real-IP  $remote_addr;
    }
{% endif %}

{% if services.music is defined and services.music.enabled %}
    # -------------------------------------------------------------------------
    # Hearth Jukebox
    # -------------------------------------------------------------------------

    # No-trailing-slash redirect
    location = /jukebox { return 301 /jukebox/; }

    # WebSocket proxy — must come before the API block
    location /jukebox/ws {
        proxy_pass         http://127.0.0.1:8766;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade    $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_set_header   Host       $host;
        proxy_read_timeout 3600s;
    }

    # Audio stream — buffering off to avoid holding the full file in memory
    location /jukebox/stream {
        proxy_pass         http://127.0.0.1:8766;
        proxy_set_header   Host       $host;
        proxy_set_header   X-Real-IP  $remote_addr;
        proxy_buffering    off;
    }

    # API proxy — all other non-static paths forwarded to the jukebox backend
    location ~* ^/jukebox/(health|queue|now-playing|rescan|library) {
        proxy_pass         http://127.0.0.1:8766;
        proxy_set_header   Host       $host;
        proxy_set_header   X-Real-IP  $remote_addr;
    }

    # Static frontend — SPA fallback so deep-links work
    location /jukebox/ {
        alias /var/www/hearth/jukebox/;
        index index.html;
        try_files $uri $uri/ /jukebox/index.html;
    }
{% endif %}


    # Service reverse-proxy stubs — uncomment the location block and remove the
    # leading '#' when the corresponding service is enabled in hearth.yaml.
{% for name, svc in services.items() if name not in ['chat', 'kiwix', 'music'] %}
{%- set port = service_ports.get(name, 'PORT') -%}
{%- if svc.enabled %}
    # {{ name }} — enabled; uncomment to activate reverse-proxy:
    # location /{{ name }}/ { proxy_pass http://127.0.0.1:{{ port }}/; }
{% else %}
    # {{ name }} — disabled (set services.{{ name }}.enabled: true in hearth.yaml)
    # location /{{ name }}/ { proxy_pass http://127.0.0.1:{{ port }}/; }
{% endif %}
{%- endfor %}
}
