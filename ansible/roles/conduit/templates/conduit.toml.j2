# conduit.toml — Conduit Matrix homeserver configuration
# Rendered by Ansible from ansible/roles/conduit/templates/conduit.toml.j2
# Do not edit this file directly — changes will be overwritten on reprovision.

[global]

# The Matrix server name — must match the domain clients connect to.
server_name = "{{ box.domain }}"

# Conduit listens on localhost; nginx proxies /_matrix/ from the public domain.
address = "127.0.0.1"
port = {{ conduit_port }}

# Database backend and storage path.
database_backend = "rocksdb"
database_path = "{{ storage.locations.conduit }}"

# Maximum upload size in bytes.  Must match client_max_body_size in nginx.
max_request_size = {{ services.chat.max_request_size | default(20000000) | int }}

# Open registration so hotspot users can create accounts without an account
# being pre-created by the operator.
allow_registration = true

{% if services.chat.registration_token is defined and services.chat.registration_token %}
# Token required at registration.  Visible only in the admin portal.
registration_token = "{{ services.chat.registration_token }}"
{% endif %}

# Federation is always disabled — this server is offline-only and must never
# attempt to contact external Matrix servers.  This is hardcoded and must not
# be changed to true, regardless of operator configuration.
allow_federation = false

# Suppress the federation warning that Conduit logs when federation is off.
allow_check_for_updates = false
