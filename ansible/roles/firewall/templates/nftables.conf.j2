# nftables.conf.j2 — Hearth firewall rules template
#
# Rendered by:  ansible roles/firewall via ansible.builtin.template
# Deployed to:  {{ firewall_nftables_conf }}
#
# Threat model (from PLAN.md §0.0):
#   - No WAN routing/NAT for connected clients.
#   - Allow DHCP (UDP 67/68), DNS (UDP/TCP 53), HTTP (TCP 80) on the AP
#     interface only.
#   - Drop everything else from clients.
#   - Allow full outbound from the box itself for build-time downloads.

flush ruleset

table inet filter {

    # -------------------------------------------------------------------------
    # INPUT chain — traffic destined for the box itself
    # -------------------------------------------------------------------------
    chain input {
        type filter hook input priority 0; policy drop;

        # Allow established / related connections (stateful tracking)
        ct state established,related accept

        # Allow loopback traffic unconditionally
        iif lo accept

        # Allow SSH on management/ethernet interfaces (not the AP interface)
        iifname != "{{ wifi.interface }}" tcp dport 22 accept comment "SSH: administrative access on non-AP interfaces"

{% if firewall_management_interface | default('') | length > 0 %}
        # Allow HTTP and Admin API on any non-AP interface so that development
        # tools (e.g. Vagrant port-forwarding) can reach the portal regardless
        # of whether the VM names its NIC eth0, enp0s3, or similar.
        # Uses a negative match (same pattern as the SSH rule above) so it is
        # robust to interface-name changes.
        # Not applied in production (firewall_management_interface is left blank
        # in the default role vars).
        iifname != "{{ wifi.interface }}" tcp dport 80   accept comment "HTTP: portal access on non-AP interfaces"
        iifname != "{{ wifi.interface }}" tcp dport 8000 accept comment "Admin API: access on non-AP interfaces"
{% endif %}

        # --- AP interface rules (clients connect here) ---

        # Threat-model: Allow DHCP requests from clients so they can obtain an
        # IP address from dnsmasq (UDP src 68 → dst 67).
        iifname "{{ wifi.interface }}" udp dport 67 accept comment "DHCP: clients request address on AP interface"

        # Threat-model: Allow DNS queries from clients (port 53) so dnsmasq
        # can serve *.hearth.local resolution and captive-portal intercept.
        iifname "{{ wifi.interface }}" tcp dport 53 accept comment "DNS/TCP: client name resolution on AP interface"
        iifname "{{ wifi.interface }}" udp dport 53 accept comment "DNS/UDP: client name resolution on AP interface"

        # Allow mDNS (UDP 5353) from AP clients so avahi-daemon can answer
        # .local name queries.  Ubuntu and other systemd-resolved clients route
        # .local lookups through mDNS (mdns4_minimal [NOTFOUND=return]) and
        # never fall back to unicast DNS — without this rule the box's avahi
        # announcements are irrelevant because client queries never arrive.
        iifname "{{ wifi.interface }}" udp dport 5353 accept comment "mDNS: client .local resolution via avahi"

        # Threat-model: Allow HTTP (port 80) from clients so the portal and
        # captive-portal redirect are reachable.
        iifname "{{ wifi.interface }}" tcp dport 80 accept comment "HTTP: portal access for AP clients"

        # Reject HTTPS (port 443) with an immediate TCP RST rather than silently
        # dropping it.  Firefox HTTPS-First mode upgrades all http:// navigations
        # to https:// before sending the original request.  A DROP causes a
        # ~3-second connection timeout before Firefox falls back to HTTP; a RST
        # tells Firefox immediately that port 443 is closed so the HTTP fallback
        # happens with no perceptible delay.
        iifname "{{ wifi.interface }}" tcp dport 443 reject with tcp reset comment "HTTPS: instant RST so browsers fall back to HTTP without delay"

        # Admin backend API (only from AP interface — not exposed to WAN)
        iifname "{{ wifi.interface }}" tcp dport 8000 accept comment "Admin API: accessible from AP interface only"

        # Threat-model: Drop everything else arriving from AP clients.
        # This is implicit from `policy drop` above, but stated explicitly
        # for documentation clarity.
        iifname "{{ wifi.interface }}" drop comment "Default-deny: drop all other client traffic"
    }

    # -------------------------------------------------------------------------
    # FORWARD chain — routing between interfaces
    # -------------------------------------------------------------------------
    chain forward {
        type filter hook forward priority 0; policy drop;

        # Threat-model: No WAN routing/NAT for connected clients.
        # All forwarded packets are dropped; the box is not a router.
        # (Explicit drop — policy is already drop, but documented here.)
        drop comment "No WAN routing: forward chain default-deny"
    }

    # -------------------------------------------------------------------------
    # OUTPUT chain — traffic originating from the box itself
    # -------------------------------------------------------------------------
    chain output {
        type filter hook output priority 0; policy accept;

        # Threat-model: Allow full outbound from the box itself so that
        # build-time downloads (apt, pip, upstream releases) are not blocked.
        # policy accept handles this; no explicit rules required.
    }
}
