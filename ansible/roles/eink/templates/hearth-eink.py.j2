#!/usr/bin/env python3
"""Render the Hearth logo and URL on a Waveshare 2.13" e-ink display (landscape).

Display: 122 × 250 px physical (portrait), rendered landscape (250 × 122 canvas).

Layout:
  Centre — fireplace SVG icon (cairosvg rasterised, scaled to fit)
  Bottom — box URL in bold, horizontally centred

Values are injected by Ansible from hearth.yaml at provision time.
"""

import argparse
import io
import logging
import sys
import time

logging.basicConfig(
    level=logging.INFO,
    format="hearth-eink: %(levelname)s %(message)s",
)
log = logging.getLogger(__name__)

# ---------------------------------------------------------------------------
# Configuration — injected by Ansible
# ---------------------------------------------------------------------------
DISPLAY_URL  = "{{ box.domain }}"
ICON_PATH    = "{{ eink_icon }}"

# ---------------------------------------------------------------------------
# Hardware pin assignments (Waveshare 2.13" V2, BCM numbering)
# ---------------------------------------------------------------------------
RST_PIN  = 17
DC_PIN   = 25
CS_PIN   = 8
BUSY_PIN = 24

EPD_WIDTH  = 122
EPD_HEIGHT = 250

# ---------------------------------------------------------------------------
# Waveshare 2.13" V2 full-update LUT
# ---------------------------------------------------------------------------
_LUT_FULL = [
    0x80,0x60,0x40,0x00,0x00,0x00,0x00,
    0x10,0x60,0x20,0x00,0x00,0x00,0x00,
    0x80,0x60,0x40,0x00,0x00,0x00,0x00,
    0x10,0x60,0x20,0x00,0x00,0x00,0x00,
    0x00,0x00,0x00,0x00,0x00,0x00,0x00,
    0x03,0x03,0x00,0x00,0x02,
    0x09,0x09,0x00,0x00,0x02,
    0x03,0x03,0x00,0x00,0x02,
    0x00,0x00,0x00,0x00,0x00,
    0x00,0x00,0x00,0x00,0x00,
    0x00,0x00,0x00,0x00,0x00,
    0x00,0x00,0x00,0x00,0x00,
    0x15,0x41,0xA8,0x32,0x30,0x0A,
]

# ---------------------------------------------------------------------------
# Font paths (DejaVu is pre-installed via fonts-dejavu-core)
# ---------------------------------------------------------------------------
_FONT_BOLD = "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf"


def _init_gpio_spi():
    import RPi.GPIO as GPIO
    import spidev

    GPIO.setmode(GPIO.BCM)
    GPIO.setup(RST_PIN,  GPIO.OUT)
    GPIO.setup(DC_PIN,   GPIO.OUT)
    GPIO.setup(CS_PIN,   GPIO.OUT)
    GPIO.setup(BUSY_PIN, GPIO.IN)
    GPIO.output(CS_PIN, GPIO.HIGH)

    spi = spidev.SpiDev()
    spi.open(0, 0)
    spi.max_speed_hz = 4000000
    spi.mode = 0b00

    return GPIO, spi


def _cmd(GPIO, spi, c):
    GPIO.output(DC_PIN, GPIO.LOW)
    GPIO.output(CS_PIN, GPIO.LOW)
    spi.writebytes([c])
    GPIO.output(CS_PIN, GPIO.HIGH)


def _data(GPIO, spi, d):
    GPIO.output(DC_PIN, GPIO.HIGH)
    GPIO.output(CS_PIN, GPIO.LOW)
    spi.writebytes([d] if isinstance(d, int) else d)
    GPIO.output(CS_PIN, GPIO.HIGH)


def _wait_busy(GPIO):
    while GPIO.input(BUSY_PIN) == 1:
        time.sleep(0.01)


def _init_display(GPIO, spi):
    cmd = lambda c: _cmd(GPIO, spi, c)
    dat = lambda d: _data(GPIO, spi, d)

    GPIO.output(RST_PIN, GPIO.HIGH); time.sleep(0.2)
    GPIO.output(RST_PIN, GPIO.LOW);  time.sleep(0.005)
    GPIO.output(RST_PIN, GPIO.HIGH); time.sleep(0.2)

    _wait_busy(GPIO)
    cmd(0x12); _wait_busy(GPIO)
    cmd(0x74); dat(0x54)
    cmd(0x7E); dat(0x3B)
    cmd(0x01); dat(0xF9); dat(0x00); dat(0x00)
    cmd(0x11); dat(0x01)
    cmd(0x44); dat(0x00); dat(0x0F)
    cmd(0x45); dat(0xF9); dat(0x00); dat(0x00); dat(0x00)
    cmd(0x3C); dat(0x03)
    cmd(0x2C); dat(0x55)
    cmd(0x03); dat(_LUT_FULL[70])
    cmd(0x04); dat(_LUT_FULL[71]); dat(_LUT_FULL[72]); dat(_LUT_FULL[73])
    cmd(0x3A); dat(_LUT_FULL[74])
    cmd(0x3B); dat(_LUT_FULL[75])
    cmd(0x32)
    for b in _LUT_FULL[:70]: dat(b)
    cmd(0x4E); dat(0x00)
    cmd(0x4F); dat(0xF9); dat(0x00)
    _wait_busy(GPIO)


def _send_image(GPIO, spi, buf):
    _cmd(GPIO, spi, 0x24)
    _data(GPIO, spi, buf)
    _cmd(GPIO, spi, 0x22)
    _data(GPIO, spi, 0xC7)
    _cmd(GPIO, spi, 0x20)
    _wait_busy(GPIO)


def _getbuffer(image):
    from PIL import Image
    rotated  = image.rotate(-90, expand=True)
    lw       = EPD_WIDTH // 8 + (1 if EPD_WIDTH % 8 else 0)
    buf      = [0xFF] * (lw * EPD_HEIGHT)
    img      = rotated.convert('1')
    pixels   = img.load()
    for y in range(EPD_HEIGHT):
        for x in range(EPD_WIDTH):
            if pixels[x, y] == 0:
                mx = EPD_WIDTH - 1 - x
                buf[mx // 8 + y * lw] &= ~(0x80 >> (mx % 8))
    return buf


def _blank_canvas():
    """Return a fully white canvas (all pixels 0xFF)."""
    from PIL import Image
    return Image.new("RGB", (EPD_HEIGHT, EPD_WIDTH), (255, 255, 255))


def _build_canvas():
    import cairosvg
    from PIL import Image, ImageDraw, ImageFont

    W, H      = EPD_HEIGHT, EPD_WIDTH   # 250 x 122 landscape
    PAD       = 8
    ICON_SIZE = 66

    # Rasterise SVG icon
    png_data  = cairosvg.svg2png(url=ICON_PATH, output_width=ICON_SIZE, output_height=ICON_SIZE)
    icon_rgba = Image.open(io.BytesIO(png_data)).convert("RGBA")
    bg        = Image.new("RGBA", icon_rgba.size, (255, 255, 255, 255))
    bg.paste(icon_rgba, mask=icon_rgba.split()[3])
    icon      = bg.convert("L").point(lambda x: 0 if x < 128 else 255, "1").convert("RGB")

    canvas = Image.new("RGB", (W, H), (255, 255, 255))

    # Icon: centred horizontally, shifted down ~2mm from top
    canvas.paste(icon, ((W - ICON_SIZE) // 2, PAD + 10))

    # URL: centred, pinned to bottom
    try:
        font = ImageFont.truetype(_FONT_BOLD, 22)
    except OSError:
        font = ImageFont.load_default()

    draw = ImageDraw.Draw(canvas)
    bbox = draw.textbbox((0, 0), DISPLAY_URL, font=font)
    tw, th = bbox[2] - bbox[0], bbox[3] - bbox[1]
    draw.text(((W - tw) // 2, H - th - PAD), DISPLAY_URL, font=font, fill=0)

    return canvas


def main():
    parser = argparse.ArgumentParser(description="Hearth e-ink display renderer")
    parser.add_argument(
        "--mode",
        choices=["logo", "blank"],
        default="logo",
        help="Display mode: 'logo' renders the Hearth logo and URL; 'blank' clears to white",
    )
    args = parser.parse_args()

    try:
        import RPi.GPIO  # noqa — confirm we're on Pi hardware
    except ImportError as exc:
        log.warning("Required library not available (%s) — display render skipped", exc)
        sys.exit(0)

    if args.mode == "logo":
        try:
            import cairosvg  # noqa
        except ImportError as exc:
            log.warning("Required library not available (%s) — display render skipped", exc)
            sys.exit(0)

    try:
        GPIO, spi = _init_gpio_spi()
        _init_display(GPIO, spi)
        canvas = _blank_canvas() if args.mode == "blank" else _build_canvas()
        _send_image(GPIO, spi, _getbuffer(canvas))
        spi.close()
        GPIO.cleanup()
        if args.mode == "blank":
            log.info("Display cleared to white")
        else:
            log.info("Display updated: url=%r", DISPLAY_URL)
    except Exception as exc:  # noqa: BLE001
        log.warning("Display update failed (%s)", exc)
        sys.exit(0)


if __name__ == "__main__":
    main()
