#!/usr/bin/env python3
"""Render the Hearth logo and URL on a Pimoroni Inky pHAT (black/white) display.

Display dimensions: 212 × 104 pixels.

Layout:
  Left  — stylised flame polygon (Hearth logo mark)
  Right — box name in large bold font
  Below — device URL centred in smaller font

Values are injected by Ansible from hearth.yaml at provision time.
"""

import logging
import sys

logging.basicConfig(
    level=logging.INFO,
    format="hearth-eink: %(levelname)s %(message)s",
)
log = logging.getLogger(__name__)

# ---------------------------------------------------------------------------
# Configuration — injected by Ansible
# ---------------------------------------------------------------------------
DISPLAY_NAME = "{{ box.name }}"
DISPLAY_URL  = "{{ box.domain }}"

# ---------------------------------------------------------------------------
# Font paths (DejaVu is pre-installed via fonts-dejavu-core)
# ---------------------------------------------------------------------------
_FONT_BOLD   = "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf"
_FONT_NORMAL = "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf"

# ---------------------------------------------------------------------------
# Flame polygon — a 7-point silhouette that fits within a ~64 × 60 px box
# starting at x=14.  Points are (x, y) from top-left of the display.
# ---------------------------------------------------------------------------
_FLAME = [
    (22, 90),   # bottom-left
    (32, 48),   # lower-left curve
    (40, 64),   # inner notch left
    (52, 18),   # top peak
    (64, 64),   # inner notch right
    (72, 48),   # lower-right curve
    (82, 90),   # bottom-right
]


def _load_fonts():
    from PIL import ImageFont
    try:
        return (
            ImageFont.truetype(_FONT_BOLD, 36),
            ImageFont.truetype(_FONT_NORMAL, 18),
        )
    except OSError:
        log.warning("DejaVu fonts not found — falling back to PIL built-in font")
        default = ImageFont.load_default()
        return default, default


def _build_image(inky):
    from PIL import Image, ImageDraw

    img  = Image.new("P", (inky.WIDTH, inky.HEIGHT), inky.WHITE)
    draw = ImageDraw.Draw(img)

    font_large, font_small = _load_fonts()

    # Flame logo mark
    draw.polygon(_FLAME, fill=inky.BLACK)

    # Box name — vertically centred in the upper ~60 px, left-aligned after flame
    draw.text((96, 20), DISPLAY_NAME, fill=inky.BLACK, font=font_large)

    # URL — horizontally centred in the lower strip
    bbox   = draw.textbbox((0, 0), DISPLAY_URL, font=font_small)
    url_w  = bbox[2] - bbox[0]
    url_x  = (inky.WIDTH - url_w) // 2
    draw.text((url_x, 74), DISPLAY_URL, fill=inky.BLACK, font=font_small)

    return img


def main():
    # Gracefully skip import errors (running in a VM without the inky library)
    try:
        from inky.auto import auto
    except ImportError as exc:
        log.warning("inky library not available (%s) — display render skipped", exc)
        sys.exit(0)

    # Gracefully skip hardware errors (no display attached, not a Pi, etc.)
    try:
        inky = auto(ask_user=True, verbose=True)
    except Exception as exc:  # noqa: BLE001
        log.warning("Could not initialise Inky display (%s) — not Pi hardware?", exc)
        sys.exit(0)

    inky.set_border(inky.WHITE)
    inky.set_image(_build_image(inky))
    inky.show()
    log.info("Display updated: name=%r url=%r", DISPLAY_NAME, DISPLAY_URL)


if __name__ == "__main__":
    main()
