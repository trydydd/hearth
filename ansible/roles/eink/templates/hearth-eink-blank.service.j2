[Unit]
Description=Hearth e-ink display — clear to all white
After=multi-user.target
Wants=multi-user.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart={{ eink_venv }}/bin/python3 {{ eink_script }} --mode blank
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
