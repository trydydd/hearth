# /etc/sudoers.d/hearth
#
# Hearth admin backend — minimal systemctl permissions.
# Rendered by: ansible roles/admin template sudoers-hearth.j2
#
# Grants the hestia user exactly the systemctl start/stop/restart
# commands required for Hearth service management — nothing else.
# Only the specific service units listed below are permitted.
#
# Validate with: visudo -c -f /etc/sudoers.d/hearth

Defaults!HEARTH_CMDS !requiretty

Cmnd_Alias HEARTH_CMDS = \
    /usr/sbin/chpasswd, \
    /bin/systemctl start hearth-chat.service, \
    /bin/systemctl stop hearth-chat.service, \
    /bin/systemctl restart hearth-chat.service, \
    /bin/systemctl start hearth-volume.service, \
    /bin/systemctl stop hearth-volume.service, \
    /bin/systemctl restart hearth-volume.service, \
    /bin/systemctl start calibre-web.service, \
    /bin/systemctl stop calibre-web.service, \
    /bin/systemctl restart calibre-web.service, \
    /bin/systemctl start kiwix.service, \
    /bin/systemctl stop kiwix.service, \
    /bin/systemctl restart kiwix.service, \
    /bin/systemctl start hearth-jukebox.service, \
    /bin/systemctl stop hearth-jukebox.service, \
    /bin/systemctl restart hearth-jukebox.service

hestia ALL=(root) NOPASSWD: HEARTH_CMDS
