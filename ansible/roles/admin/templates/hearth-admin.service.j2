[Unit]
Description=Hearth admin backend
Documentation=https://github.com/trydydd/cafe-box
After=network.target hearth-first-boot.service
Wants=network.target

[Service]
Type=simple
User=hearth-admin
Group=hearth-admin
# shadow group membership is required so the backend can read /etc/shadow
# for PAM / spwd-based password verification.
SupplementaryGroups=shadow
WorkingDirectory=/opt/hearth/admin/backend
EnvironmentFile=/etc/hearth/admin.env
ExecStart=/opt/hearth/admin/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=5s
PrivateTmp=true

[Install]
WantedBy=multi-user.target
