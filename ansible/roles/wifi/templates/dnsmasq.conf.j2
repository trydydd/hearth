# dnsmasq.conf.j2 — Hearth DNS + DHCP configuration template
#
# Rendered by:  ansible roles/wifi via ansible.builtin.template
# Deployed to:  {{ wifi_dnsmasq_conf }}
#
# Driven by the wifi / box sections of hearth.yaml / group_vars/all.yml.
#
# Responsibilities:
#   1. Resolve *.hearth.local (and all other DNS queries) to the box IP —
#      captive-portal intercept so every domain loads the portal.
#   2. Serve DHCP leases on the AP interface to connected clients.

# -------------------------------------------------------------------------
# Interface binding
# -------------------------------------------------------------------------

# Only listen on the AP interface (not on ethernet or loopback)
interface={{ wifi.interface }}

# Bind only to the interface above; do not listen on wildcard
bind-interfaces

# -------------------------------------------------------------------------
# DHCP
# -------------------------------------------------------------------------

# Hand out addresses in the configured range with the given lease time
dhcp-range={{ wifi.dhcp_range_start }},{{ wifi.dhcp_range_end }},{{ wifi.dhcp_lease }}

# Tell clients to use the box as their default gateway and DNS server
dhcp-option=option:router,{{ box.ip }}
dhcp-option=option:dns-server,{{ box.ip }}

# -------------------------------------------------------------------------
# DNS — captive portal intercept
# -------------------------------------------------------------------------

# Do not forward unresolved names to upstream DNS (the box is offline)
no-resolv

# Resolve *.hearth.local to the box IP so every local service is reachable
address=/{{ box.domain }}/{{ box.ip }}

# Return the box IP for ALL other DNS queries — this is the captive-portal
# intercept: any domain a client requests resolves to the box, which then
# redirects to the portal via nginx's /generate_204 and similar locations.
address=/#/{{ box.ip }}

# -------------------------------------------------------------------------
# Logging (minimal — reduce writes on SD card)
# -------------------------------------------------------------------------
log-dhcp
quiet-dhcp
